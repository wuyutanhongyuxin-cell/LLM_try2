# LLM API Key（三选一即可，由 config/llm.yaml 的 model 字段决定用哪个）
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...

# 基础设施（可选）
REDIS_URL=redis://localhost:6379/0
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# 可选 — 加密货币数据源（Binance）
BINANCE_BASE_URL=https://api.binance.com

# 可选 — CME 期货数据源（Databento）
DATABENTO_API_KEY=db-...

LOG_LEVEL=INFO

# 可选 — Lighter DEX 实盘交易
LIGHTER_API_KEY_PRIVATE_KEY=0x...
LIGHTER_ACCOUNT_INDEX=0
LIGHTER_API_KEY_INDEX=0
